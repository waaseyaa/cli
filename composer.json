{
    "name": "waaseyaa/cli",
    "description": "Command-line interface and console commands for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../ai-agent"
        },
        {
            "type": "path",
            "url": "../audit"
        },
        {
            "type": "path",
            "url": "../cache"
        },
        {
            "type": "path",
            "url": "../config"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../groups"
        },
        {
            "type": "path",
            "url": "../http-client"
        },
        {
            "type": "path",
            "url": "../migration"
        },
        {
            "type": "path",
            "url": "../northcloud"
        },
        {
            "type": "path",
            "url": "../queue"
        },
        {
            "type": "path",
            "url": "../scheduler"
        },
        {
            "type": "path",
            "url": "../user"
        },
        {
            "type": "path",
            "url": "../ai-vector"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../oidc"
        },
        {
            "type": "path",
            "url": "../plugin"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../search"
        },
        {
            "type": "path",
            "url": "../workflows"
        }
    ],
    "require": {
        "php": ">=8.5",
        "symfony/console": "^8.0",
        "waaseyaa/access": "^0.1.0-alpha.267",
        "waaseyaa/ai-agent": "^0.1.0-alpha.267",
        "waaseyaa/audit": "^0.1.0-alpha.267",
        "waaseyaa/cache": "^0.1.0-alpha.267",
        "waaseyaa/config": "^0.1.0-alpha.267",
        "waaseyaa/entity": "^0.1.0-alpha.267",
        "waaseyaa/entity-storage": "^0.1.0-alpha.267",
        "waaseyaa/groups": "^0.1.0-alpha.267",
        "waaseyaa/http-client": "^0.1.0-alpha.267",
        "waaseyaa/migration": "^0.1.0-alpha.267",
        "waaseyaa/northcloud": "^0.1.0-alpha.267",
        "waaseyaa/queue": "^0.1.0-alpha.267",
        "waaseyaa/scheduler": "^0.1.0-alpha.267",
        "waaseyaa/user": "^0.1.0-alpha.267",
        "waaseyaa/ai-vector": "^0.1.0-alpha.267",
        "waaseyaa/database-legacy": "^0.1.0-alpha.267",
        "waaseyaa/field": "^0.1.0-alpha.267",
        "waaseyaa/foundation": "^0.1.0-alpha.267",
        "waaseyaa/oidc": "^0.1.0-alpha.267",
        "waaseyaa/plugin": "^0.1.0-alpha.267",
        "waaseyaa/routing": "^0.1.0-alpha.267",
        "waaseyaa/search": "^0.1.0-alpha.267",
        "waaseyaa/workflows": "^0.1.0-alpha.267"
    },
    "suggest": {
        "ext-intl": "For ICU transliteration of diacritic titles to readable Latin ingest keys; a deterministic hash key is used otherwise",
        "ext-pcntl": "Required for clean SIGINT handling in --watch mode"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "bin": [
        "bin/waaseyaa"
    ],
    "autoload": {
        "psr-4": {
            "Waaseyaa\\CLI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\CLI\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        },
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\CLI\\CliServiceProvider",
                "Waaseyaa\\CLI\\Provider\\AiServiceProvider",
                "Waaseyaa\\CLI\\Provider\\AuditServiceProvider",
                "Waaseyaa\\CLI\\Provider\\BundleFixtureServiceProvider",
                "Waaseyaa\\CLI\\Provider\\EntityTypeServiceProvider",
                "Waaseyaa\\CLI\\Provider\\GroupsCliServiceProvider",
                "Waaseyaa\\CLI\\Provider\\HealthSchemaServiceProvider",
                "Waaseyaa\\CLI\\Provider\\ImportServiceProvider",
                "Waaseyaa\\CLI\\Provider\\WorkflowsServiceProvider",
                "Waaseyaa\\CLI\\Provider\\MakeServiceProviderA",
                "Waaseyaa\\CLI\\Provider\\MakeServiceProviderB",
                "Waaseyaa\\CLI\\Provider\\MakeStorageMigrationServiceProvider",
                "Waaseyaa\\CLI\\Provider\\MigrateServiceProvider",
                "Waaseyaa\\CLI\\Provider\\OptimizeServiceProvider",
                "Waaseyaa\\CLI\\Provider\\QueueServiceProvider",
                "Waaseyaa\\CLI\\Provider\\SchedulePerfServiceProvider",
                "Waaseyaa\\CLI\\Provider\\IngestSearchSemanticServiceProvider",
                "Waaseyaa\\CLI\\Provider\\UserPermissionServiceProvider",
                "Waaseyaa\\CLI\\Provider\\ConfigCacheDbAuditServiceProvider",
                "Waaseyaa\\CLI\\Provider\\MiscAServiceProvider",
                "Waaseyaa\\CLI\\Provider\\MiscBServiceProvider",
                "Waaseyaa\\CLI\\Provider\\OtherScaffoldsServiceProvider",
                "Waaseyaa\\CLI\\Provider\\NorthCloudServiceProvider",
                "Waaseyaa\\CLI\\Provider\\OidcServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
