#!/usr/bin/env php
<?php

declare(strict_types=1);

// Project root is the current working directory. This contract matches
// Laravel's artisan and Symfony's bin/console: the CLI must be invoked
// from the project root (the directory containing composer.json).
//
// Deliberately avoids __DIR__-based resolution: __DIR__ canonicalizes
// through symlinks, so a consumer that symlinks vendor/waaseyaa/cli for
// local-dev would have __DIR__ resolve to the framework repo, not the
// consumer project. See ADR-005.
$projectRoot = getcwd();

if ($projectRoot === false || !file_exists($projectRoot . '/composer.json')) {
    fwrite(STDERR, "waaseyaa: must be run from a project root (directory containing composer.json).\n");
    fwrite(STDERR, 'current directory: ' . ($projectRoot === false ? '(unknown)' : $projectRoot) . "\n");
    exit(1);
}

$autoload = $projectRoot . '/vendor/autoload.php';
if (!file_exists($autoload)) {
    fwrite(STDERR, "waaseyaa: vendor/autoload.php not found in {$projectRoot}. Run 'composer install' first.\n");
    exit(1);
}
require $autoload;

$kernel = new Waaseyaa\Foundation\Kernel\ConsoleKernel($projectRoot);
exit($kernel->handle());
