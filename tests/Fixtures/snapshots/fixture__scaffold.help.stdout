Description:
  Generate deterministic workflow + relationship fixture scenario JSON

Usage:
  fixture:scaffold [options]

Options:
      --key=KEY                                  Scenario node key (machine name)
      --title=TITLE                              Scenario node title
      --bundle=BUNDLE                            Node bundle/type [default: "article"]
      --workflow-state=WORKFLOW-STATE            Workflow state [default: "draft"]
      --status=STATUS                            Publication status override (0/1)
      --uid=UID                                  Fixture author UID [default: "1"]
      --timestamp=TIMESTAMP                      Deterministic fixture timestamp [default: "1735689600"]
      --relationship-type=RELATIONSHIP-TYPE      Optional relationship type
      --to-key=TO-KEY                            Optional target fixture key for relationship
      --relationship-status=RELATIONSHIP-STATUS  Relationship status (0/1) [default: "1"]
  -o, --output=OUTPUT                            Optional output file path (.json)
  -h, --help                                     Display help for the given command. When no command is given display help for the list command
      --silent                                   Do not output any message
  -q, --quiet                                    Only errors are displayed. All other output is suppressed
  -V, --version                                  Display this application version
      --ansi|--no-ansi                           Force (or disable --no-ansi) ANSI output
  -n, --no-interaction                           Do not ask any interactive question
  -v|vv|vvv, --verbose                           Increase the verbosity of messages: 1 for normal output, 2 for more verbose output and 3 for debug
